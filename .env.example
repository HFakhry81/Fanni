# ─── Fanni — Environment Variables ───────────────────────────────────────────
#
# Copy this file to .env for local development:
#   cp .env.example .env
#
# On Replit: all variables are set automatically via the Replit environment.
# Locally:   fill in the values below and run:
#              pnpm --filter @workspace/api-server run dev
#              pnpm --filter @workspace/mobile run dev
#
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Local PostgreSQL (PgAdmin 4 default): postgresql://postgres:<password>@localhost:5432/fanni_db
# Create the DB first:  createdb fanni_db  OR  use PgAdmin 4 to create it
DATABASE_URL="postgresql://postgres:123456@localhost:5432/fanni_db"

# ── API Server ────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# ── Session ───────────────────────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_a_random_32byte_hex_string

# ── OTP / Auth ────────────────────────────────────────────────────────────────
# false = skip OTP in dev (password login only). true = require OTP (needs SMS).
ENABLE_OTP=false

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Leave all SMTP_ vars unset to disable email in dev (OTPs/resets logged to console).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_gmail_app_password
# SMTP_FROM=Fanni <noreply@fanni.app>

# ── SMS ───────────────────────────────────────────────────────────────────────
# Leave all SMS_ vars unset to disable SMS in dev (OTP codes logged to console).
# SMS_PROVIDER=vonage
# SMS_API_KEY=your_vonage_key
# SMS_API_SECRET=your_vonage_secret
# SMS_FROM_NUMBER=+20xxxxxxxxxx
# SMS_SENDER_ID=Fanni

# ── Object Storage (file uploads) ─────────────────────────────────────────────
# On Replit: GCS bucket is provisioned automatically — do NOT set PRIVATE_OBJECT_DIR.
# Locally:   set PRIVATE_OBJECT_DIR to a local folder; uploads go there instead.
PRIVATE_OBJECT_DIR=./uploads

# ── OpenAI / OCR ──────────────────────────────────────────────────────────────
# On Replit: provided by the AI integration — AI_INTEGRATIONS_OPENAI_API_KEY is
#            injected automatically; do NOT set it here.
# Locally:   set your own key. The OCR invoice feature will be unavailable without it.
# AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ── Maps / Geo ────────────────────────────────────────────────────────────────
# Optional — needed only for real-time traffic overlays.
# TOMTOM_API_KEY=your_tomtom_key

# ── Order Broadcasting ────────────────────────────────────────────────────────
# Radius in km for notifying nearby technicians. Defaults: 10 km, tiers 5/10/20.
# BROADCAST_RADIUS_KM=10
# BROADCAST_RADIUS_TIERS_KM=5,10,20

# ── Mobile App (Expo) ─────────────────────────────────────────────────────────
# Point the mobile app at the local API server.
# On Replit: EXPO_PUBLIC_API_URL is set automatically by scripts/dev-start.js.
# Locally:   set this to your machine's local API URL.
EXPO_PUBLIC_API_URL=http://localhost:8080
