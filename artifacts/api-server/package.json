{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development pnpm run build && pnpm run start",
    "prebuild": "pnpm --filter @workspace/db --filter @workspace/api-zod build",
    "build": "node ./build.mjs",
    "prestart": "pnpm --filter @workspace/db run migrate",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "pnpm --filter @workspace/db --filter @workspace/api-zod build && tsc -p tsconfig.json --noEmit",
    "normalize-areas": "pnpm --filter @workspace/db build && tsx src/scripts/normalizeOrderAreas.ts",
    "check-areas": "pnpm --filter @workspace/db build && tsx src/scripts/checkAreaHealth.ts",
    "backfill-locations": "pnpm --filter @workspace/db build && tsx migrations/010-backfill-user-locations.ts",
    "backfill-centroids": "pnpm --filter @workspace/db build && tsx migrations/013-backfill-location-centroids.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "google-auth-library": "^10.6.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "openai": "^6.34.0",
    "openid-client": "^6.8.3",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "pino": "^9",
    "pino-http": "^10",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "catalog:",
    "@types/ws": "^8.18.1",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "catalog:",
    "vitest": "^4.1.5"
  }
}
