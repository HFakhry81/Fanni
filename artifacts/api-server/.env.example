# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/fanni

# Session / JWT signing (required — no default)
SESSION_SECRET=change-me-to-a-long-random-secret

# OTP phone verification
# false (default): registration is accepted without a valid OTP token (development / testing)
# true            : a verified OTP token is required to complete registration or admin creation
ENABLE_OTP=false

# SMS gateway (optional — when absent, OTP codes are logged to the console)
# SMS_API_KEY=your_sms_api_key
