# ─── Fanni Mobile App — Local Development Environment ────────────────────────
#
# Copy this file to .env for local development:
#   cp artifacts/mobile/.env.example artifacts/mobile/.env
#
# On Replit: all variables are set automatically — do NOT create a .env file.
# Locally:   fill in EXPO_PUBLIC_API_URL with your machine's local IP.
#
# ─────────────────────────────────────────────────────────────────────────────

# ── API Server URL ────────────────────────────────────────────────────────────
# Point this at your local API server (port 8080 by default).
#
# For Expo Web in the browser on the same machine:
#   EXPO_PUBLIC_API_URL=http://localhost:8080
#
# For Expo Go on a physical phone (same Wi-Fi network):
#   Replace <YOUR_LOCAL_IP> with your machine's LAN IP (e.g. 192.168.1.42)
#   Find it with:  ip addr show (Linux) / ipconfig (Windows) / ifconfig (macOS)
#
EXPO_PUBLIC_API_URL=http://localhost:8080

# ── OTP (optional) ───────────────────────────────────────────────────────────
# Set ENABLE_OTP=false in the API server's .env to skip OTP during local dev.
# (No setting needed here — this is controlled server-side.)
